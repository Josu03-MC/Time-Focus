{
  "dependencies": {
    "express": "^4.18.2",
    "pug": "^3.0.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1",
    "tailwindcss": "^3.4.0"
  },
  "scripts": {
    "dev": "concurrently \"nodemon app.js\" \"tailwindcss -i ./src/public/css/app.css -o ./src/public/css/output.css --watch\"",
    "start": "node app.js",
    "watch:css": "tailwindcss -i ./src/public/css/app.css -o ./src/public/css/output.css --watch",
    "build:css": "tailwindcss -i ./src/public/css/app.css -o ./src/public/css/output.css"
  }
}
